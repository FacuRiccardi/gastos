{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": ["postgresql@17"],
  "env": {
    "PGDATA": "$PWD/.devbox/virtenv/postgresql/data",
    "PGHOST": "/tmp",
    "PGPORT": "5432",
    "PGUSER": "postgres",
    "DATABASE_URL": "postgresql://postgres@localhost:5432/gastos",
    "TEST_DATABASE_URL": "postgresql://postgres@localhost:5432/gastos_test"
  },
  "shell": {
    "init_hook": [
      "if [ ! -f \"$PGDATA/PG_VERSION\" ]; then initdb --auth=trust --no-locale --encoding=UTF8 --username=postgres; fi"
    ],
    "scripts": {
      "setup": [
        "createdb gastos 2>/dev/null || echo 'gastos already exists'",
        "createdb gastos_test 2>/dev/null || echo 'gastos_test already exists'",
        "npm run db:push:test"
      ],
      "test:integration": ["npm run test:integration"],
      "test": ["npm test"]
    }
  }
}
